@{
}
<form asp-action="viewByBranch" method="post">
    <select name="branchId">
        <option value="0">Select Branch</option>
        @foreach (var i in ViewBag.branches)
        {
            <option value="@i.branchId">@i.branchName</option>
        }
    </select>
    <input type="submit" value="search" />
</form>
@if (TempData["custCount"] != null)
{
    <br />
    <br />
    <h2>No. of Customer : @TempData["custCount"]</h2>
    <br />
    <br />
    <h2>No. of Staff : @TempData["staffCount"]</h2>
    <br />
}